# ============================================================
# ActiPlan Lead Discovery Engine - Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git (see .gitignore).
# ============================================================

# --- Discovery Sources (Tier 1 - keyword search, free tiers) ---

# Jooble: https://jooble.org/api/about (free, no card required)
JOOBLE_API_KEY=

# Adzuna: https://developer.adzuna.com (free, no card required)
# Leave blank until approved - the connector is skipped automatically
# if these are empty, the run continues with the remaining sources.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# --- ATS Direct Sources (Tier 2) ---
# Optional. Points to a slug->company_name watchlist for Greenhouse,
# Lever, and Ashby. Leave blank to skip ATS-direct polling entirely.
ATS_WATCHLIST_FILE=./config/ats_watchlist.json

# --- Search Configuration ---
# Comma-separated search terms used to query discovery sources.
# Keep this short and high-signal; the title filter downstream does
# the fine-grained matching against HIGH_PRIORITY_TITLES / MEDIUM_PRIORITY_TITLES.
SEARCH_TERMS=paid media,performance marketing,media buyer,paid social,PPC,media planner

# Countries to search, ISO 3166-1 alpha-2, comma-separated.
# Used by connectors that support country-scoped search (e.g. Adzuna).
SEARCH_COUNTRIES=gb,us,de,fr,nl,ae

# --- Filtering ---
# Path to the canonical title -> score mapping. Edit that file to add,
# remove, or re-weight job titles - no code changes needed.
TITLE_SCORES_FILE=./config/title_scores.json

# Minimum fuzzy-match confidence (0-100) for a raw job title to be
# considered a match against the configured title list. Lower = more
# permissive (catches more title variants, more false positives).
FUZZY_MATCH_THRESHOLD=82

# --- Scoring ---
# Jobs scoring below this threshold are discarded and never written
# to the leads table or exported to Google Sheets.
MIN_SCORE=50

# --- Database ---
DATABASE_PATH=./data/lead_discovery.db

# --- Google Sheets Export ---
GOOGLE_SHEET_ID=
# Path to a Google service account JSON credentials file.
GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/service_account.json

# --- Logging ---
# One of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
LOG_FILE=./logs/lead_discovery.log
